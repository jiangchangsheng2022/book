---
interface Props {
  lang?: 'zh' | 'en';
  current?: string;
}
const { lang = 'zh', current = '' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navZh = [
  { href: `${base}/`, label: '首页', key: 'home' },
  { href: `${base}/templates/`, label: '模板包', key: 'templates' },
  { href: `${base}/glossary/`, label: '术语词典', key: 'glossary' },
  { href: `${base}/tools/`, label: '工具地图', key: 'tools' },
  { href: `${base}/compliance/`, label: '合规清单', key: 'compliance' },
  { href: `${base}/cases/`, label: '真实案例', key: 'cases' },
  { href: `${base}/newsletter/`, label: '刊物', key: 'newsletter' },
  { href: `${base}/errata/`, label: '勘误', key: 'errata' },
  { href: `${base}/about/`, label: '关于', key: 'about' },
];

const navEn = [
  { href: `${base}/en/`, label: 'Home', key: 'home' },
  { href: `${base}/en/glossary/`, label: 'Glossary', key: 'glossary' },
  { href: `${base}/en/about/`, label: 'About', key: 'about' },
];

const nav = lang === 'en' ? navEn : navZh;
const homeHref = lang === 'en' ? `${base}/en/` : `${base}/`;
const altLangHref = lang === 'en' ? `${base}/` : `${base}/en/`;
const altLangLabel = lang === 'en' ? '中文' : 'EN';
---

<header class="site-header">
  <div class="container-wide site-header-inner">
    <a class="site-brand" href={homeHref}>
      <span class="site-brand-mark">用</span>
      <span class="site-brand-text">
        <span class="site-brand-title">用户研究：从入门到精通</span>
        <span class="site-brand-subtitle">
          {lang === 'en' ? 'Reader Companion · Jiang Changsheng' : '读者服务网站 · 蒋昌盛'}
        </span>
      </span>
    </a>

    <button class="nav-toggle" aria-label="菜单" aria-expanded="false" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav" aria-label="主导航">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class={current === item.key ? 'is-current' : ''}
              aria-current={current === item.key ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="lang-switch">
          <a href={altLangHref}>{altLangLabel}</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(253, 252, 249, 0.92);
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  @media (prefers-color-scheme: dark) {
    .site-header { background: rgba(22, 20, 15, 0.9); }
  }

  .site-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-5);
    min-height: 64px;
  }

  .site-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
    text-decoration: none;
  }
  .site-brand:hover { text-decoration: none; color: var(--color-text); }

  .site-brand-mark {
    width: 36px; height: 36px;
    border-radius: var(--radius);
    background: var(--color-accent);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 18px;
    flex-shrink: 0;
  }
  .site-brand-text { display: flex; flex-direction: column; line-height: 1.2; }
  .site-brand-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--color-text);
  }
  .site-brand-subtitle {
    font-size: 0.74rem;
    color: var(--color-text-faint);
    margin-top: 2px;
  }

  .site-nav ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }
  .site-nav a {
    display: inline-block;
    padding: 0.45em 0.8em;
    color: var(--color-text-soft);
    font-size: var(--text-sm);
    border-radius: var(--radius-sm);
  }
  .site-nav a:hover {
    color: var(--color-accent);
    background: var(--color-bg-soft);
    text-decoration: none;
  }
  .site-nav a.is-current {
    color: var(--color-accent);
    font-weight: 500;
  }
  .lang-switch a {
    border: 1px solid var(--color-border);
    margin-left: var(--space-2);
    font-size: 0.78rem;
  }

  /* 移动端 */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 38px; height: 38px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 18px; height: 2px;
    background: var(--color-text);
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .nav-toggle { display: flex; }
    .site-nav {
      position: absolute;
      top: 100%;
      left: 0; right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .site-nav.is-open { max-height: 80vh; }
    .site-nav ul {
      flex-direction: column;
      align-items: stretch;
      padding: var(--space-3);
      gap: 0;
    }
    .site-nav a {
      padding: 0.7em 0.8em;
      border-bottom: 1px solid var(--color-border);
    }
    .lang-switch a {
      border: none;
      margin-left: 0;
    }
    .site-brand-subtitle { display: none; }
  }
</style>

<script is:inline>
  (function () {
    const btn = document.getElementById('nav-toggle');
    const nav = document.getElementById('site-nav');
    if (!btn || !nav) return;
    btn.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  })();
</script>
