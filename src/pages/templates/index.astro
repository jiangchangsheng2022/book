---
import BaseLayout from '../../layouts/BaseLayout.astro';
import templates from '../../data/templates.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="模板包"
  description="《用户研究：从入门到精通》配套 8 份免费研究模板：研究计划书、甄别问卷、知情同意书、访谈提纲、问卷模板、用户画像、用户旅程图、研究报告 PPT。"
  current="templates"
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">附录 D · 数字资源</p>
      <h1>研究模板包</h1>
      <p class="lead">
        覆盖一次研究项目从立项到交付的所有节点。每份模板都是从我真实的项目里磨出来的，
        所有内容免费，可以直接复制使用，也可以根据自己业务场景做改造。
      </p>

      <div class="placeholder-banner">
        当前页面以"占位 + 描述"形式呈现。下一轮我会把每份模板的实际 .docx / .pptx 文件挂上来。
      </div>

      <div class="grid grid-2 mt-6">
        {templates.map((t) => (
          <a href={`${base}/templates/${t.slug}/`} class="card template-card">
            <div class="template-card-meta">
              <span class="tag">{t.category}</span>
              <span class="text-faint">{t.format}</span>
            </div>
            <h3 class="mb-0">{t.title}</h3>
            <p class="text-faint stage">{t.stage}</p>
            <p class="text-soft summary">{t.summary}</p>
            <p class="template-card-cta">查看详情 →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .template-card {
      display: flex;
      flex-direction: column;
      color: inherit;
      text-decoration: none;
    }
    .template-card:hover { text-decoration: none; }
    .template-card-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--space-3);
      font-size: var(--text-sm);
    }
    .stage {
      font-size: var(--text-sm);
      margin-bottom: var(--space-3);
    }
    .summary {
      flex-grow: 1;
      margin-bottom: var(--space-3);
    }
    .template-card-cta {
      color: var(--color-accent);
      font-weight: 500;
      margin: 0;
    }
  </style>
</BaseLayout>
