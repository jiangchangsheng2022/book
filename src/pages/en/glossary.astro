---
import BaseLayout from '../../layouts/BaseLayout.astro';
import glossary from '../../data/glossary.json';

// Use the same dataset; English version filters to terms that have an English form.
const categories = Object.values(glossary.categories);
const terms = glossary.terms;
---

<BaseLayout
  title="Glossary"
  description="80+ user research terms in English and Chinese, searchable and filterable."
  lang="en"
  current="glossary"
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Appendix A · Glossary</p>
      <h1>Glossary</h1>
      <p class="lead">
        {terms.length} user research terms across {categories.length} categories. Definitions are
        currently in Chinese; English translations of definitions will be added in future updates.
      </p>

      <div class="placeholder-banner">
        Term names are in English/Chinese; full definitions will be translated to English progressively.
      </div>

      <div class="glossary-controls">
        <input
          type="search"
          id="glossary-search-en"
          placeholder="Search terms, abbreviations, or definitions…"
          aria-label="Search terms"
        />
        <div class="category-filters" id="category-filters-en">
          <button class="filter-btn is-active" data-category="all">All</button>
          {categories.map((c) => (
            <button class="filter-btn" data-category={c}>{c}</button>
          ))}
        </div>
      </div>

      <p class="result-count text-faint" id="result-count-en">
        Showing {terms.length} of {terms.length}
      </p>

      <ul class="term-list" id="term-list-en">
        {terms.map((t) => (
          <li
            class="term-item"
            data-category={t.category}
            data-search={`${t.en} ${t.zh} ${t.def}`.toLowerCase()}
          >
            <div class="term-head">
              {t.en && <span class="term-en">{t.en}</span>}
              {t.zh && <span class="term-zh">{t.zh}</span>}
              <span class="tag term-cat">{t.category}</span>
            </div>
            <p class="term-def">{t.def}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .glossary-controls { margin: var(--space-5) 0 var(--space-3); }
    #glossary-search-en {
      width: 100%;
      padding: 0.7em 1em;
      font-size: var(--text-base);
      border: 1px solid var(--color-border-strong);
      background: var(--color-bg-elevated);
      color: var(--color-text);
      border-radius: var(--radius);
      font-family: inherit;
    }
    #glossary-search-en:focus {
      outline: none;
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px var(--color-accent-soft);
    }
    .category-filters {
      display: flex; flex-wrap: wrap; gap: var(--space-2);
      margin-top: var(--space-3);
    }
    .filter-btn {
      padding: 0.35em 0.9em;
      font-size: var(--text-sm);
      background: transparent;
      color: var(--color-text-soft);
      border: 1px solid var(--color-border);
      border-radius: 999px;
      cursor: pointer;
      font-family: inherit;
    }
    .filter-btn:hover { background: var(--color-bg-soft); }
    .filter-btn.is-active {
      background: var(--color-accent); color: #fff; border-color: var(--color-accent);
    }
    .result-count { font-size: var(--text-sm); margin: var(--space-3) 0; }
    .term-list { list-style: none; padding: 0; margin: 0; }
    .term-item {
      padding: var(--space-4) 0;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 0;
    }
    .term-item[hidden] { display: none; }
    .term-head {
      display: flex; flex-wrap: wrap; align-items: baseline;
      gap: var(--space-3); margin-bottom: var(--space-2);
    }
    .term-en {
      font-family: var(--font-serif); font-weight: 600;
      font-size: var(--text-lg); color: var(--color-text);
    }
    .term-zh {
      font-family: var(--font-serif); font-size: var(--text-lg);
      color: var(--color-accent);
    }
    .term-cat { margin-left: auto; font-size: var(--text-xs); }
    .term-def { margin: 0; color: var(--color-text-soft); line-height: 1.7; }
  </style>

  <script is:inline>
    (function () {
      const search = document.getElementById('glossary-search-en');
      const filterBtns = document.querySelectorAll('#category-filters-en .filter-btn');
      const items = document.querySelectorAll('#term-list-en .term-item');
      const countEl = document.getElementById('result-count-en');
      let activeCategory = 'all', activeQuery = '';
      const total = items.length;
      function applyFilters() {
        let shown = 0;
        items.forEach((item) => {
          const cat = item.dataset.category;
          const haystack = item.dataset.search || '';
          const matchCat = activeCategory === 'all' || cat === activeCategory;
          const matchQuery = !activeQuery || haystack.includes(activeQuery);
          const visible = matchCat && matchQuery;
          item.hidden = !visible;
          if (visible) shown++;
        });
        countEl.textContent = `Showing ${shown} of ${total}`;
      }
      search.addEventListener('input', (e) => {
        activeQuery = e.target.value.trim().toLowerCase();
        applyFilters();
      });
      filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          filterBtns.forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          activeCategory = btn.dataset.category;
          applyFilters();
        });
      });
    })();
  </script>
</BaseLayout>
