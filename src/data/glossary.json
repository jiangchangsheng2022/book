{
  "categories": {
    "1": "主要研究概念",
    "2": "设计与原型术语",
    "3": "研究方法与类型",
    "4": "项目流程术语",
    "5": "产品与体验指标",
    "6": "数据分析与处理",
    "7": "问卷与访谈术语",
    "8": "数据合规与伦理",
    "9": "技术术语",
    "10": "常用缩写",
    "11": "互联网行业术语"
  },
  "terms": [
    {
      "en": "Insight",
      "zh": "洞察",
      "def": "用户研究的主要产出。它不是对事实的简单陈述，而是透过纷繁复杂的数据和现象，提炼出的关于用户行为、需求和动机的深层理解，能够直接启发产品和战略决策。",
      "category": "主要研究概念"
    },
    {
      "en": "Persona",
      "zh": "用户画像",
      "def": "基于真实的用户数据，虚构出的一个典型用户模型。它有姓名、有照片、有目标、有痛点，旨在让抽象的用户群体变得有血有肉，帮助团队建立同理心和统一的认知。",
      "category": "主要研究概念"
    },
    {
      "en": "Qualitative Research",
      "zh": "定性研究",
      "def": "一种探索性的研究方法，旨在深入理解人们行为背后的为什么。它不追求大样本，而是通过访谈、观察等方式，获取丰富、深入的故事和观点，用于发现机会和形成假设。",
      "category": "主要研究概念"
    },
    {
      "en": "Quantitative Research",
      "zh": "定量研究",
      "def": "一种验证性的研究方法，旨在衡量现象的普遍性。它通过问卷、实验等方式，收集大量可统计的数据，用于验证假设、衡量市场规模，回答有多少、是什么的问题。",
      "category": "主要研究概念"
    },
    {
      "en": "User Journey Map",
      "zh": "用户旅程图",
      "def": "一种可视化工具，用于描绘用户为了达成某个目标，与产品或服务进行互动时的完整过程。它能清晰地展现用户在不同阶段的行为、想法、情绪和痛点。",
      "category": "主要研究概念"
    },
    {
      "en": "Design System",
      "zh": "设计系统",
      "def": "一套服务于产品设计和开发的、系统化的规范和组件库。它确保了产品在视觉和交互上的一致性，并提升了设计和开发的效率。",
      "category": "设计与原型术语"
    },
    {
      "en": "Information Architecture",
      "zh": "信息架构",
      "def": "指对信息进行组织、构建和标签化的艺术与科学，旨在让用户能更容易地找到信息和理解内容。它是一个产品的骨骼系统。",
      "category": "设计与原型术语"
    },
    {
      "en": "Prototype",
      "zh": "原型",
      "def": "在投入正式开发前，用于测试和沟通的产品概念的可视化、可交互的模型。分为低保真原型（如线框图）和高保真原型。",
      "category": "设计与原型术语"
    },
    {
      "en": "Usability",
      "zh": "可用性",
      "def": "衡量一个产品对特定用户在特定场景下，能够有效、高效、并感到满意地达成目标的程度。简单来说，就是产品好不好用。",
      "category": "设计与原型术语"
    },
    {
      "en": "A/B",
      "zh": "",
      "def": "Testing一种在线实验方法。将用户随机分为A、B两组，让他们使用不同的方案，通过真实的后台数据来比较哪个方案能更好地达成目标。",
      "category": "研究方法与类型"
    },
    {
      "en": "BHT",
      "zh": "",
      "def": "品牌健康度追踪。通过定期的、持续的定量调研，监测品牌及其竞争对手的市场健康指标。",
      "category": "研究方法与类型"
    },
    {
      "en": "Card Sorting",
      "zh": "卡片分类法",
      "def": "让用户将代表内容或功能的卡片进行分组和命名，以理解用户的心理模型，常用于信息架构设计。",
      "category": "研究方法与类型"
    },
    {
      "en": "Concept Test",
      "zh": "概念测试",
      "def": "在产品开发早期，将初步构想呈现给目标用户，以评估其吸引力、可理解度和使用意愿。",
      "category": "研究方法与类型"
    },
    {
      "en": "Diary Study",
      "zh": "日记研究",
      "def": "一种纵向研究方法，邀请用户在一段时间内，持续地记录下他们与某个主题相关的行为、想法和感受。",
      "category": "研究方法与类型"
    },
    {
      "en": "Ethnography",
      "zh": "人种志研究",
      "def": "一种沉浸式的定性研究方法，研究员深入到用户的真实生活或工作环境中进行长期观察，以理解其文化、行为和深层需求。",
      "category": "研究方法与类型"
    },
    {
      "en": "Focus Group",
      "zh": "焦点小组",
      "def": "邀请6-8名背景相似的用户，在一位主持人引导下，就某一主题进行集体讨论，通过观点碰撞激发更多想法。",
      "category": "研究方法与类型"
    },
    {
      "en": "Funnel Analysis",
      "zh": "漏斗分析",
      "def": "一种定量分析方法，用于衡量用户在一个多步骤流程中（如注册、购物）每一步的转化和流失情况。",
      "category": "研究方法与类型"
    },
    {
      "en": "Heuristic Evaluation",
      "zh": "启发式评估",
      "def": "由用户体验专家依据公认的可用性原则，对产品界面进行成体系检查，找出潜在设计问题的方法。",
      "category": "研究方法与类型"
    },
    {
      "en": "In-depth Interview",
      "zh": "深度访谈",
      "def": "由研究员与一位用户进行的一对一、半结构化的深入对话，旨在挖掘用户的深层动机、需求和故事。",
      "category": "研究方法与类型"
    },
    {
      "en": "JTBD",
      "zh": "",
      "def": "一种理论框架，认为用户购买和使用产品，是在雇佣它来完成自己生活中的某项任务。",
      "category": "研究方法与类型"
    },
    {
      "en": "Segmentation",
      "zh": "市场细分研究",
      "def": "基于用户的特征、需求或行为，将庞大的市场划分为若干个特征鲜明的子群体的过程。",
      "category": "研究方法与类型"
    },
    {
      "en": "Survey",
      "zh": "问卷调查",
      "def": "通过设计一系列标准化的、结构性的问题，向大量用户进行发放和收集，从而进行定量统计分析的方法。",
      "category": "研究方法与类型"
    },
    {
      "en": "Tracking Study",
      "zh": "追踪研究",
      "def": "一种持续性的、定期重复进行的研究项目，用于监测市场或用户行为随时间的变化趋势。",
      "category": "研究方法与类型"
    },
    {
      "en": "U&A",
      "zh": "",
      "def": "使用与态度研究。一种全面的市场研究，旨在系统地了解消费者在某个品类中的使用习惯、购买行为、品牌认知和态度等。",
      "category": "研究方法与类型"
    },
    {
      "en": "Usability Testing",
      "zh": "可用性测试",
      "def": "通过观察真实用户使用产品来评估其易用性的主要方法。",
      "category": "研究方法与类型"
    },
    {
      "en": "Workshop",
      "zh": "工作坊",
      "def": "一种协作式的会议形式，组织不同背景的参与者，在一个结构化的流程引导下，共同进行分析、创意或决策。",
      "category": "研究方法与类型"
    },
    {
      "en": "Backlog",
      "zh": "需求池",
      "def": "在产品开发中，用于记录所有待开发的功能、修复的Bug和改进项的列表。",
      "category": "项目流程术语"
    },
    {
      "en": "Brief",
      "zh": "",
      "def": "需求简报。由业务方发起，用于描述研究背景、商业目标和初步需求的文件。",
      "category": "项目流程术语"
    },
    {
      "en": "Cold Start",
      "zh": "冷启动",
      "def": "指一个新产品或新功能在没有任何历史数据和用户基础的情况下，开始运营和推荐的过程。",
      "category": "项目流程术语"
    },
    {
      "en": "Debrief",
      "zh": "每日复盘",
      "def": "在访谈或测试执行期间，项目组在每日工作结束后进行的简短复盘会议。",
      "category": "项目流程术语"
    },
    {
      "en": "Deliverable",
      "zh": "交付物",
      "def": "研究项目结束后，需要交付的最终成果，如研究报告、用户画像等。",
      "category": "项目流程术语"
    },
    {
      "en": "FW",
      "zh": "",
      "def": "实地执行。指研究项目中进行数据收集的阶段。",
      "category": "项目流程术语"
    },
    {
      "en": "Grayscale Release",
      "zh": "灰度发布",
      "def": "也称金丝雀发布。一种软件发布策略，指让一部分用户先行使用新版本，如无问题再逐步扩大范围，最终全量发布，以降低风险。",
      "category": "项目流程术语"
    },
    {
      "en": "Kick-off",
      "zh": "项目启动会",
      "def": "在项目正式开始前，召集所有主要利益相关者，对齐项目目标、范围、计划和分工的会议。",
      "category": "项目流程术语"
    },
    {
      "en": "Proposal",
      "zh": "",
      "def": "研究计划书。由研究员撰写，详细阐述研究目标、方法、对象、排期和预算的方案文件。",
      "category": "项目流程术语"
    },
    {
      "en": "Stakeholder",
      "zh": "利益相关者",
      "def": "受项目影响或能影响项目的个人或团体。",
      "category": "项目流程术语"
    },
    {
      "en": "Topline",
      "zh": "",
      "def": "中期报告/核心判断报告。在完整报告完成前，快速呈现核心发现与初步结论的简要报告。",
      "category": "项目流程术语"
    },
    {
      "en": "AARRR Model",
      "zh": "海盗模型",
      "def": "一个衡量产品增长的经典漏斗模型，包含获取、启动、留存、收入、传播五个环节。",
      "category": "产品与体验指标"
    },
    {
      "en": "CSAT",
      "zh": "",
      "def": "客户满意度。衡量用户对某次具体互动或体验的满意程度。",
      "category": "产品与体验指标"
    },
    {
      "en": "CTR",
      "zh": "",
      "def": "点击率。广告或链接被点击的次数占其总曝光（展示）次数的比例。",
      "category": "产品与体验指标"
    },
    {
      "en": "Churn Rate",
      "zh": "流失率",
      "def": "在特定时期内，停止使用产品或服务的用户所占的比例。",
      "category": "产品与体验指标"
    },
    {
      "en": "Conversion Rate",
      "zh": "转化率",
      "def": "完成了我们所期望的某个特定行为（如注册、购买）的用户比例。",
      "category": "产品与体验指标"
    },
    {
      "en": "DAU/MAU",
      "zh": "日/月活跃用户",
      "def": "Daily / Monthly Active Users。衡量产品用户规模和活跃度的主要指标。",
      "category": "产品与体验指标"
    },
    {
      "en": "HEART",
      "zh": "",
      "def": "Framework由Google提出的用户体验度量框架，包含愉悦度、参与度、接受度、留存率、任务完成度五个维度。",
      "category": "产品与体验指标"
    },
    {
      "en": "LTV",
      "zh": "",
      "def": "用户生命周期价值。预估一个用户在整个生命周期中能为企业带来的总价值。",
      "category": "产品与体验指标"
    },
    {
      "en": "NPS",
      "zh": "",
      "def": "净推荐值。衡量用户忠诚度的关键指标，通过询问用户有多大意愿推荐来计算。",
      "category": "产品与体验指标"
    },
    {
      "en": "Retention Rate",
      "zh": "留存率",
      "def": "在初次访问后的特定时间点（如第7天、第30天），仍然会回来继续使用的用户比例。",
      "category": "产品与体验指标"
    },
    {
      "en": "SUS",
      "zh": "",
      "def": "系统可用性量表。一个由10个问题组成的行业标准问卷，用于快速评估产品的整体可用性。",
      "category": "产品与体验指标"
    },
    {
      "en": "Affinity Diagram",
      "zh": "亲和图",
      "def": "一种将大量零散的定性数据进行归类、整理，并发现其内在结构的分析方法。",
      "category": "数据分析与处理"
    },
    {
      "en": "Coding",
      "zh": "编码",
      "def": "在定性分析中，为表达了某个特定意思的文本或行为片段，贴上一个标签的过程。",
      "category": "数据分析与处理"
    },
    {
      "en": "Incidence Rate",
      "zh": "",
      "def": "符合率。在抽样调查中，符合所有甄别条件的目标受访者在总接触人群中所占的比例。IR的高低直接影响招募的难度和成本。",
      "category": "数据分析与处理"
    },
    {
      "en": "Quota",
      "zh": "配额",
      "def": "在调研项目中，为了确保样本结构能代表目标人群，预先设定的不同特征的受访者数量要求。",
      "category": "数据分析与处理"
    },
    {
      "en": "Sample Size",
      "zh": "样本量",
      "def": "一次研究中所包含的个体或样本的数量。",
      "category": "数据分析与处理"
    },
    {
      "en": "Sig",
      "zh": "",
      "def": "显著性检验。一种统计学方法，用于判断两组或多组数据之间的差异是否真实存在。",
      "category": "数据分析与处理"
    },
    {
      "en": "Verbatim",
      "zh": "逐字稿",
      "def": "将访谈或焦点小组的录音，一字不差地转录成的文字稿。",
      "category": "数据分析与处理"
    },
    {
      "en": "Weighting",
      "zh": "加权",
      "def": "当实际回收的样本结构与默认的配额不符时，通过为样本赋予不同的权重，来调整数据，使其在整体上符合目标人群的结构。",
      "category": "数据分析与处理"
    },
    {
      "en": "Closed-ended Question",
      "zh": "封闭式问题",
      "def": "提供固定选项（如是/否、选择题）的问题，便于定量统计。",
      "category": "问卷与访谈术语"
    },
    {
      "en": "Likert Scale",
      "zh": "李克特量表",
      "def": "一种常见的态度度量方法，让用户在对称的量表上（如非常不同意到非常同意）表达自己的认同程度。",
      "category": "问卷与访谈术语"
    },
    {
      "en": "Open-ended Question",
      "zh": "开放式问题",
      "def": "不提供固定选项，允许用户用自己的话自由回答的问题。",
      "category": "问卷与访谈术语"
    },
    {
      "en": "Probing",
      "zh": "追问",
      "def": "在定性访谈中，针对用户的某个回答，进行更深层次、更具体的提问，以挖掘背后的原因和细节。",
      "category": "问卷与访谈术语"
    },
    {
      "en": "Rapport",
      "zh": "融洽关系",
      "def": "在访谈初期，主持人与受访者之间建立起的相互信任、放松、和谐的交流氛围。",
      "category": "问卷与访谈术语"
    },
    {
      "en": "Screener",
      "zh": "甄别问卷",
      "def": "在招募受访者时，用于快速筛选、判断候选人是否符合目标用户画像的一系列问题。",
      "category": "问卷与访谈术语"
    },
    {
      "en": "Anonymization",
      "zh": "匿名化",
      "def": "在处理和呈现数据时，移除所有可能识别到具体个人的信息，以保护用户隐私。",
      "category": "数据合规与伦理"
    },
    {
      "en": "GDPR",
      "zh": "",
      "def": "欧盟通用数据保护条例。欧盟出台的、全球范围内最严格的个人数据保护法规。",
      "category": "数据合规与伦理"
    },
    {
      "en": "Informed Consent",
      "zh": "知情同意",
      "def": "在研究开始前，向参与者清晰、完整地告知研究的所有相关信息，并获得他们主动、自愿的同意。是所有研究的伦理基石。",
      "category": "数据合规与伦理"
    },
    {
      "en": "PII",
      "zh": "",
      "def": "个人可识别信息。指任何可以用来识别、联系或定位特定个人的信息，如姓名、电话、地址等。",
      "category": "数据合规与伦理"
    },
    {
      "en": "API",
      "zh": "",
      "def": "应用程序编程界面。是一组规则，允许不同的软件应用之间相互通信和数据交换。",
      "category": "技术术语"
    },
    {
      "en": "H5",
      "zh": "",
      "def": "第五代超文本标记语言。是构建网页内容的主要技术标准。",
      "category": "技术术语"
    },
    {
      "en": "NLP",
      "zh": "",
      "def": "自然语言处理。是人工智能的一个分支，致力于让计算机能够理解和处理人类的自然语言。",
      "category": "技术术语"
    },
    {
      "en": "Tracking",
      "zh": "埋点",
      "def": "一种数据采集方法，通过在网页或App页面中嵌入代码，来追踪和记录用户在该页面上的行为。",
      "category": "技术术语"
    },
    {
      "en": "B2B/B2C",
      "zh": "",
      "def": "Business-to-Business / Business-to-Consumer。两种不同的商业模式，前者指企业对企业的业务，后者指企业对个人消费者的业务。",
      "category": "常用缩写"
    },
    {
      "en": "IC",
      "zh": "",
      "def": "个人贡献者。指在团队中不承担管理职责，依靠个人专业能力完成工作的角色。",
      "category": "常用缩写"
    },
    {
      "en": "UI",
      "zh": "",
      "def": "用户界面。指用户与产品交互的视觉部分，如按钮、图标、布局等。",
      "category": "常用缩写"
    },
    {
      "en": "UR/UER",
      "zh": "",
      "def": "用户研究/用户体验研究。",
      "category": "常用缩写"
    },
    {
      "en": "UX",
      "zh": "",
      "def": "用户体验。指用户在使用一个产品或服务过程中的全部感受和情绪的总和。",
      "category": "常用缩写"
    },
